{
  "name": "orderful",
  "version": "1.0.1",
  "description": "MCP server for the Orderful EDI API — exposes Orderful's trading-partner, transaction, delivery, and conversion endpoints as MCP tools over stdio or HTTP.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "orderful": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && cp src/oauth-login.html src/favicon.svg dist/",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "orderful",
    "edi",
    "ai",
    "claude",
    "anthropic"
  ],
  "author": "Ilyasse Salama",
  "license": "MIT",
  "homepage": "https://github.com/ilyassesalama/orderful-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ilyassesalama/orderful-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/ilyassesalama/orderful-mcp/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "express": "^5.1.0",
    "ioredis": "^5.11.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  }
}
